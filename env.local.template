# =============================================================================
# MehmanGhar Financial OS — Environment Variables
# mg-finance-os / .env.local
#
# IMPORTANT: This file must NEVER be committed to version control.
# Ensure .env.local is listed in .gitignore before adding real values.
# Copy this template to .env.local and fill in all values before running.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE — Supabase PostgreSQL via Prisma
#
# Both URLs point to the same Supabase Postgres instance.
# DIRECT_URL is required by Prisma when going through Supabase's connection
# pooler (port 6543). Using the direct connection (port 5432) for both is
# also valid during development but the pooler URL is preferred in production.
#
# Find these in: Supabase Dashboard → Project → Settings → Database → Connection string
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"


# -----------------------------------------------------------------------------
# SUPABASE — JS Client (Storage operations only)
#
# These are used exclusively by src/lib/supabase.ts and src/lib/storage.ts.
# No API route or component imports @supabase/supabase-js directly.
#
# NEXT_PUBLIC_SUPABASE_URL        — Safe to expose. Used by browser storage client.
# NEXT_PUBLIC_SUPABASE_ANON_KEY  — Safe to expose. Read-only public access.
# SUPABASE_SERVICE_ROLE_KEY      — NEVER expose to browser. Server-side only.
#                                   Used for admin-level storage operations.
#
# Find these in: Supabase Dashboard → Project → Settings → API
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key]"
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"


# -----------------------------------------------------------------------------
# AUTHENTICATION — JWT + bcrypt
#
# JWT_SECRET: Used by jose to sign and verify HS256 tokens stored in the
#             HttpOnly cookie. Must be a strong random string (min 32 chars).
#             Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# BCRYPT_ROUNDS: bcrypt work factor. Plan specifies 12.
#
# COOKIE_NAME: Name of the HttpOnly session cookie. Must match in middleware.ts
#              and all auth API routes.
# -----------------------------------------------------------------------------

JWT_SECRET="[replace-with-strong-random-secret-min-32-chars]"
BCRYPT_ROUNDS="12"
COOKIE_NAME="mg_session"


# -----------------------------------------------------------------------------
# SUPERADMIN SEED CREDENTIALS
#
# Used once during Phase 3 to seed the initial SuperAdmin account.
# These values are read server-side only by the seed script.
# The seeded password is hashed with bcrypt — this plaintext is not stored.
#
# OPEN DECISION #1 (v3 plan, Section 12): Confirm username and initial password
# with business owner before Phase 3 begins.
# -----------------------------------------------------------------------------

SEED_SUPERADMIN_USERNAME="[superadmin-username]"
SEED_SUPERADMIN_PASSWORD="[superadmin-initial-password]"


# -----------------------------------------------------------------------------
# APPLICATION
#
# NODE_ENV is set automatically by Next.js (development / production).
# NEXT_PUBLIC_APP_URL is used for any server-generated absolute URLs
# (e.g. in email links, if added in future scope).
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL="http://localhost:3000"


# =============================================================================
# PRODUCTION OVERRIDES (Vercel)
#
# When deploying to Vercel, all variables above must be added via:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# Set separate values for Preview and Production environments as needed.
# NEXT_PUBLIC_APP_URL should be set to the deployed domain in production:
#   NEXT_PUBLIC_APP_URL="https://mg-finance-os.vercel.app"
# =============================================================================
